# ──────────────────────────────────────────────────────────────────────────
# Anfaia Daily AI — environment variables
# Copy this file to `.env` and fill in the values.
# ──────────────────────────────────────────────────────────────────────────

# --- Application --------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=false

# --- Database -----------------------------------------------------------------
# Single source of truth for the PostgreSQL connection. The app builds
# DATABASE_URL from these parts when DATABASE_URL is not set.
# docker-compose also uses them to initialize the `postgres` container.
POSTGRES_USER=anfaia
POSTGRES_PASSWORD=anfaia
POSTGRES_DB=anfaia
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Full async DSN (optional). If set, it TAKES PRECEDENCE over the POSTGRES_*
# variables above. Leave it empty to let it be assembled automatically.
# Note: in docker-compose the host must be `postgres` (compose sets it).
# DATABASE_URL=postgresql+asyncpg://anfaia:anfaia@localhost:5432/anfaia

# --- LLM providers ------------------------------------------------------------
# Select the active provider: openai | anthropic | openrouter
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# --- Embeddings ---------------------------------------------------------------
# Embedding provider: openai | hash (hash = deterministic local fallback)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
# Cosine similarity threshold to consider two news items duplicates (0-1)
DUPLICATE_SIMILARITY_THRESHOLD=0.86

# --- Discord ------------------------------------------------------------------
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=
# Optional: separate channel for the weekly newsletter announcement.
# Leave empty to reuse DISCORD_CHANNEL_ID. The bot must have permissions there too.
NEWSLETTER_DISCORD_CHANNEL_ID=

# --- Scheduler ----------------------------------------------------------------
SCHEDULER_ENABLED=true
POST_TIME=09:00
TIMEZONE=Europe/Madrid

# --- Weekly newsletter --------------------------------------------------------
# Master switch for the weekly HTML newsletter (off by default).
NEWSLETTER_ENABLED=false
# Soft cap on stories (grows automatically to fit one story per category).
NEWSLETTER_TOP_N=6
# Minimum relevance score (0-100) for a story to be eligible.
NEWSLETTER_MIN_RELEVANCE=50
# Extra stories beyond the per-category floor must score at least this (0-100).
NEWSLETTER_EXTRA_RELEVANCE=80
# Cosine threshold to consider two stories the same within the issue (0-1).
NEWSLETTER_DEDUP_THRESHOLD=0.86
# When to publish (cron day-of-week + HH:MM in TIMEZONE). 'mon' = Monday.
NEWSLETTER_DAY_OF_WEEK=mon
NEWSLETTER_POST_TIME=09:00
# Path prefix (folder) for the weekly permalinks inside the Pages repo.
NEWSLETTER_PATH_PREFIX=newsletters
# Logo shown in the HTML header.
NEWSLETTER_LOGO_URL=https://anfaia.org/ANFAIA_logo_web.png
# Public base URL where GitHub Pages serves the repo (required when enabled).
# e.g. https://<owner>.github.io/<repo>
NEWSLETTER_BASE_URL=

# --- GitHub Pages (newsletter hosting) ----------------------------------------
# Fine-grained PAT with 'Contents: Read and write' on the Pages repo.
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=gh-pages

# --- Weekly podcast (generated from the newsletter) ---------------------------
# Turns the week's selected stories into a two-host dialogue, renders it to audio
# and publishes the episode + an RSS feed (feed.xml) on GitHub Pages, embeds a
# player in the newsletter HTML and announces it on Discord.
# Requires the GitHub Pages + NEWSLETTER_BASE_URL config above.
PODCAST_ENABLED=false

# Episode engine: 'classic' (own scriptwriter agent + TTS line by line) or
# 'genfm' (ElevenLabs Studio generates script AND audio; needs
# ELEVENLABS_API_KEY + PODCAST_VOICE_A/B, and ignores TTS_PROVIDER).
PODCAST_ENGINE=classic
# GenFM tuning: episode language, optional extra style instructions, and how
# long to wait for Studio's background conversion (it can take minutes).
GENFM_LANGUAGE=es
GENFM_INSTRUCTIONS=
GENFM_POLL_SECONDS=10
GENFM_TIMEOUT_SECONDS=900

# TTS backend for the classic engine: 'elevenlabs' (MP3, recommended for the
# public feed) or 'gemini' (Google multi-speaker TTS, NotebookLM-style; WAV).
TTS_PROVIDER=elevenlabs

# ElevenLabs credentials and model (used when TTS_PROVIDER=elevenlabs).
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2

# Google Gemini TTS (used when TTS_PROVIDER=gemini).
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Per-host "voice": an ElevenLabs voice id (e.g. 21m00Tcm4TlvDq8ikWAM) when using
# ElevenLabs, OR a Gemini prebuilt voice name (e.g. Kore, Puck) when using Gemini.
PODCAST_VOICE_A=
PODCAST_VOICE_B=
# Display names used by the scriptwriter for each host.
PODCAST_VOICE_A_NAME=Lucía
PODCAST_VOICE_B_NAME=Mateo
# Target episode length in minutes (guides the script length).
PODCAST_TARGET_MINUTES=8
# On-disk cache for synthesized lines (ElevenLabs): re-running a week reuses the
# cached audio instead of paying the API again. Empty disables the cache.
TTS_CACHE_DIR=var/tts_cache
# Optional intro/outro jingles (local paths). MUST be MP3 CBR 128 kbps 44.1 kHz
# (same encoding as the TTS output): they are byte-concatenated with the episode.
# E.g. ffmpeg -i jingle.wav -codec:a libmp3lame -b:a 128k -ar 44100 intro.mp3
PODCAST_INTRO_PATH=
PODCAST_OUTRO_PATH=
# OR the id of a track generated with ElevenLabs (e.g. Eleven Music): it is
# downloaded from your account history (GET /v1/history/{id}/audio) and cached
# in TTS_CACHE_DIR. Takes precedence over the local path when both are set.
PODCAST_INTRO_ELEVENLABS_ID=
PODCAST_OUTRO_ELEVENLABS_ID=
# Folder under the Pages site for the MP3s and feed.xml.
PODCAST_PATH_PREFIX=podcast
# RSS channel metadata (shown in Spotify/Apple).
PODCAST_TITLE=Anfaia Weekly AI
PODCAST_AUTHOR=Anfaia
PODCAST_DESCRIPTION=El repaso semanal en español de las noticias de IA más relevantes, en formato conversación.
PODCAST_LANGUAGE=es-ES
PODCAST_EMAIL=
# Optional separate Discord channel for the podcast (falls back to the newsletter one).
PODCAST_DISCORD_CHANNEL_ID=

# --- Orchestration ------------------------------------------------------------
# Daily pipeline engine:
#   sequential = deterministic in-code pipeline (single-shot agents)
#   deepagents = deliberative editorial decision (requires: pip install '.[deepagents]')
WORKFLOW_ENGINE=sequential
# Number of unique candidates the editorial brain chooses from (deepagents)
EDITORIAL_SHORTLIST_SIZE=5
# Cap on the deep agent's reasoning-loop iterations
DEEPAGENTS_RECURSION_LIMIT=50

# --- Collection ---------------------------------------------------------------
# Max number of items fetched per source
MAX_ITEMS_PER_SOURCE=15
# Minimum relevance score (0-100) for a news item to be a candidate
MIN_RELEVANCE_SCORE=55
# User-Agent used on outbound HTTP requests
HTTP_USER_AGENT=AnfaiaDailyAI/0.1 (+https://anfaia.org)
HTTP_TIMEOUT_SECONDS=20
# RSS catalog override: "Name|URL" entries separated by commas (or newlines).
# Leave empty to use the built-in catalog (see app/infrastructure/sources/registry.py).
# Example: RSS_FEEDS=Mi Blog|https://mi.blog/feed,Otro|https://otro.com/rss
RSS_FEEDS=
# Subreddits to monitor (comma-separated). Empty disables the Reddit source.
REDDIT_SUBREDDITS=artificial,MachineLearning
# Include the Hacker News source
HACKERNEWS_ENABLED=true
# Fetch the full article body before editing (best-effort; falls back to the
# feed summary when the page cannot be retrieved or is too thin).
ARTICLE_FETCH_ENABLED=true
ARTICLE_FETCH_MAX_CHARS=8000
